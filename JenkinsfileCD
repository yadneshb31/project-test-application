pipeline {
    agent any

    environment {
        AWS_REGION   = "us-east-1"
        CLUSTER_NAME = "3RI-devops-eks-cluster"
        NAMESPACE    = "springboot"
        IMAGE_NAME   = "mangeshc225/test-application"
        IMAGE_TAG    = "latest"
    }

    stages {

        stage('Authenticate to AWS') {
            steps {
                withCredentials([
                    [$class: 'AmazonWebServicesCredentialsBinding',
                     credentialsId: 'aws-creds']
                ]) {

                    sh '''
                    aws sts get-caller-identity

                    aws eks update-kubeconfig \
                        --region $AWS_REGION \
                        --name $CLUSTER_NAME

                    kubectl get nodes
                    '''
                }
            }
        }

        stage('Verify Docker Image Exists') {
            steps {
                sh '''
                echo "Checking Docker Hub image..."
                docker pull $IMAGE_NAME:$IMAGE_TAG
                '''
            }
        }

        stage('Deploy to EKS') {
            steps {
                withCredentials([
                    [$class: 'AmazonWebServicesCredentialsBinding',
                     credentialsId: 'aws-creds']
                ]) {

                    sh '''
                    set -e

                    kubectl apply -f K8s/namespace.yml
                    kubectl apply -f K8s/configmap.yml
                    kubectl apply -f K8s/service.yml
                    kubectl apply -f K8s/ingress.yml

                    kubectl apply -f K8s/deployment.yml

                    kubectl set image deployment/springboot-app \
                    springboot-app=$IMAGE_NAME:$IMAGE_TAG \
                    -n $NAMESPACE

                    kubectl rollout status deployment/springboot-app -n $NAMESPACE
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "Deployment successful - image pulled from Docker Hub"
        }

        failure {
            echo "Deployment failed - check image or cluster access"
        }
    }
}