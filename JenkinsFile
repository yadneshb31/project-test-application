pipeline {

    agent any

    environment {
        git_credentials = credentials('github-cred')
    }

    stages {
        stage('checkout') {
            steps {
                git branch: 'main', credentialsId: 'github-cred', url: 'https://github.com/mangeshchauhan/Test-application.git'
            }
        }
        stage('deploy') {
            steps {
                sh 'chmod +x hello.sh'
                sh './hello.sh'
            }
        }
    }
}